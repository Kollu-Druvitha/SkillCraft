# Server port
PORT=5000

# MongoDB connection string
# Local:   mongodb://127.0.0.1:27017/student_management
# Atlas:   mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/student_management
MONGO_URI=mongodb://127.0.0.1:27017/student_management

# JWT secret key (use a long random string in production)
JWT_SECRET=replace_this_with_a_long_random_secret_key

# JWT token expiry
JWT_EXPIRES_IN=1d
